# Worker-server template. Copy as config.mk on the second server.
NODE_ROLE := worker

MODEL := Qwen/Qwen3.6-27B-FP8
SERVED_MODEL_NAME := qwen3.6-27b-fp8

# API still runs on the head server.
HOST := 192.14.88.2
BIND_HOST := 0.0.0.0
PORT := 8001

# RAY_HEAD_IP is the head's private/VPN IP.
RAY_HEAD_IP := 192.14.88.2
# Replace with this worker's private/VPN IP.
RAY_NODE_IP := 10.10.0.12
RAY_PORT := 6379
RAY_EXPECTED_NODES := 2
RAY_EXPECTED_GPUS := 2
RAY_CLUSTER_START_TIMEOUT := 900

RAY_NODE_MANAGER_PORT := 10002
RAY_OBJECT_MANAGER_PORT := 10003
RAY_MIN_WORKER_PORT := 11000
RAY_MAX_WORKER_PORT := 11100
RAY_DASHBOARD_AGENT_PORT := 52365
RAY_DASHBOARD_AGENT_GRPC_PORT := 52366
RAY_RUNTIME_ENV_AGENT_PORT := 52367

CUDA_VISIBLE_DEVICES := 0
TENSOR_PARALLEL_SIZE := 1
PIPELINE_PARALLEL_SIZE := 2
DISTRIBUTED_EXECUTOR_BACKEND := ray

MAX_MODEL_LEN := 8192
MAX_NUM_SEQS := 1
GPU_MEMORY_UTILIZATION := 0.90
CPU_OFFLOAD_GB := 0
SWAP_SPACE_GB := 4
DTYPE := auto
KV_CACHE_DTYPE := auto
ENABLE_PREFIX_CACHING := true
CALCULATE_KV_SCALES := false
MAX_IMAGES_PER_PROMPT := 1
REASONING_PARSER := qwen3
ENABLE_AUTO_TOOL_CHOICE := true
TOOL_CALL_PARSER := qwen3_coder
ALLOWED_MEDIA_DOMAIN := invalid.invalid

HF_HOME := $(CURDIR)/cache/huggingface

# Use the same interface names as on head, e.g. wg0 or eth1.
NCCL_SOCKET_IFNAME :=
GLOO_SOCKET_IFNAME :=
NCCL_DEBUG := WARN
NCCL_IB_DISABLE :=
