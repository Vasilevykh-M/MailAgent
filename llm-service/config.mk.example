# Профиль Ubuntu 24.04 с одной RTX 5090. Скопируйте как config.mk.
NODE_ROLE := head

MODEL := Qwen/Qwen3.5-9B
SERVED_MODEL_NAME := qwen3.5-9b

# API доступен в доверенной LAN только на IP этого LLM-хоста.
HOST := 192.168.88.251
BIND_HOST := 192.168.88.251
PORT := 8001

# Ray требует фактический адрес хоста, а не loopback.
RAY_HEAD_IP := 192.168.88.251
RAY_NODE_IP := 192.168.88.251
RAY_PORT := 6379
RAY_EXPECTED_NODES := 1
RAY_EXPECTED_GPUS := 1
RAY_CLUSTER_START_TIMEOUT := 120

RAY_NODE_MANAGER_PORT := 10002
RAY_OBJECT_MANAGER_PORT := 10003
RAY_MIN_WORKER_PORT := 11000
RAY_MAX_WORKER_PORT := 11100
RAY_DASHBOARD_AGENT_PORT := 52365
RAY_DASHBOARD_AGENT_GRPC_PORT := 52366
RAY_RUNTIME_ENV_AGENT_PORT := 52367

CUDA_VISIBLE_DEVICES := 0
TENSOR_PARALLEL_SIZE := 1
PIPELINE_PARALLEL_SIZE := 1
DISTRIBUTED_EXECUTOR_BACKEND := ray

# 32 ГиБ VRAM RTX 5090: веса Qwen помещаются в GPU без CPU-offload.
MAX_MODEL_LEN := 8192
MAX_NUM_SEQS := 2
GPU_MEMORY_UTILIZATION := 0.90
CPU_OFFLOAD_GB := 0
DTYPE := bfloat16
KV_CACHE_DTYPE := auto
ENABLE_PREFIX_CACHING := false
CALCULATE_KV_SCALES := false
# Qwen3.5-9B — мультимодальная модель. Агент использует только текст, поэтому
# визуальные модули не загружаются и OCR-fallback в VLM отключён.
LANGUAGE_MODEL_ONLY := true
REASONING_PARSER :=
ENABLE_AUTO_TOOL_CHOICE := false
TOOL_CALL_PARSER :=

HF_HOME := $(CURDIR)/cache/huggingface

# Для одного хоста параметры сетевого кластера не нужны.
NCCL_SOCKET_IFNAME :=
GLOO_SOCKET_IFNAME :=
NCCL_DEBUG := WARN
NCCL_IB_DISABLE :=
