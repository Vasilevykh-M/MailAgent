# Профиль одного Linux-хоста с одной RTX 2060. Скопируйте как config.mk.
NODE_ROLE := head

MODEL := Qwen/Qwen3.5-9B
SERVED_MODEL_NAME := qwen3.5-9b

# API предназначен для локального mail-agent. Для удалённых клиентов используйте
# reverse proxy с TLS, а не открывайте vLLM напрямую.
HOST := 127.0.0.1
BIND_HOST := 127.0.0.1
PORT := 8001

# Ray требует фактический адрес хоста, а не loopback. При нескольких сетевых
# интерфейсах задайте один private/VPN IP вручную в обеих строках.
RAY_HEAD_IP := $(shell hostname -I 2>/dev/null | awk '{print $$1}')
RAY_NODE_IP := $(RAY_HEAD_IP)
RAY_PORT := 6379
RAY_EXPECTED_NODES := 1
RAY_EXPECTED_GPUS := 1
RAY_CLUSTER_START_TIMEOUT := 120

RAY_NODE_MANAGER_PORT := 10002
RAY_OBJECT_MANAGER_PORT := 10003
RAY_MIN_WORKER_PORT := 11000
RAY_MAX_WORKER_PORT := 11100
RAY_DASHBOARD_AGENT_PORT := 52365
RAY_DASHBOARD_AGENT_GRPC_PORT := 52366
RAY_RUNTIME_ENV_AGENT_PORT := 52367

CUDA_VISIBLE_DEVICES := 0
TENSOR_PARALLEL_SIZE := 1
PIPELINE_PARALLEL_SIZE := 1
DISTRIBUTED_EXECUTOR_BACKEND := ray

# Профиль для 8 ГиБ VRAM: 0.90 оставляет KV-cache после загрузки весов.
MAX_MODEL_LEN := 4096
MAX_NUM_SEQS := 1
GPU_MEMORY_UTILIZATION := 0.90
# Нужны минимум 32 ГиБ RAM: веса, не поместившиеся в VRAM, загружаются в RAM.
CPU_OFFLOAD_GB := 14
DTYPE := half
KV_CACHE_DTYPE := auto
ENABLE_PREFIX_CACHING := false
CALCULATE_KV_SCALES := false
# Qwen3.5-9B — мультимодальная модель. Агент использует только текст, поэтому
# визуальные модули не загружаются и OCR-fallback в VLM отключён.
LANGUAGE_MODEL_ONLY := true
REASONING_PARSER :=
ENABLE_AUTO_TOOL_CHOICE := false
TOOL_CALL_PARSER :=

HF_HOME := $(CURDIR)/cache/huggingface

# Для одного хоста параметры сетевого кластера не нужны.
NCCL_SOCKET_IFNAME :=
GLOO_SOCKET_IFNAME :=
NCCL_DEBUG := WARN
NCCL_IB_DISABLE :=
