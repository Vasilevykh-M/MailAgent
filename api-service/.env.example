DATABASE_URL=postgresql+asyncpg://mail_agent:change-me@postgres:5432/mail_agent
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=mail-agent
S3_REGION=us-east-1
S3_SECURE=false
WRITER_API_KEY=
READER_API_KEY=
ALLOW_ANONYMOUS_READER=false
# Bootstrap администратора. Обе переменные обязательны для включения.
AUTH_ADMIN_USERNAME=
AUTH_ADMIN_PASSWORD=
# Время жизни пользовательской сессии в секундах (от 300 до 604800).
AUTH_SESSION_TTL_SECONDS=28800
# Число случайных байтов session token (не менее 32).
AUTH_TOKEN_BYTES=32
# Через сколько секунд после logout можно удалить отозванную сессию.
AUTH_REVOKED_SESSION_RETENTION_SECONDS=604800
# Origin frontend preview/production через запятую, например http://localhost:4173.
CORS_ALLOWED_ORIGINS=http://localhost:4173
MAX_MESSAGE_BYTES=26214400
MAX_ATTACHMENT_BYTES=26214400
MAX_ATTACHMENTS_PER_MESSAGE=30
PARTITIONS_MONTHS_AHEAD=3
LOG_LEVEL=INFO
