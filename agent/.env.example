AGENT_CONFIG=./agent/config.yaml
AGENT_WORK_DIR=./var/mail-agent
AGENT_DB_PATH=./var/mail-agent/state.sqlite3
AGENT_CHECKPOINT_DB_PATH=./var/mail-agent/checkpoints.sqlite3
PIPELINE_VERSION=3
MAIL_ENV_FILE=./yandex/mail/.env
MAILBOX=INBOX
POLL_INTERVAL_SECONDS=60
MAIL_BATCH_SIZE=50
MAX_CONCURRENT_MESSAGES=1
MARK_READ_AFTER_SUCCESS=true
LLM_BASE_URL=http://192.168.88.251:8001/v1
LLM_API_KEY=
LLM_MODEL=qwen3.5-9b
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=3
LLM_MAX_TEXT_CHARS_PER_REQUEST=6000
LLM_MAX_COMPLETION_TOKENS=1000
LLM_MAX_OCR_CORRECTION_TOKENS=1000
OCR_BASE_URL=http://192.14.88.2:8000
OCR_FALLBACK_TO_VLM=false
OCR_TIMEOUT_SECONDS=300
OCR_MAX_RETRIES=3
RESULTS_API_BASE_URL=http://127.0.0.1:8080
RESULTS_API_KEY=
RESULTS_API_TIMEOUT_SECONDS=300
RESULTS_API_MAX_RETRIES=3
RESULTS_API_VERIFY_TLS=true
LOG_LEVEL=INFO
