AGENT_CONFIG=./agent/config.yaml
AGENT_WORK_DIR=./var/mail-agent
AGENT_DB_PATH=./var/mail-agent/state.sqlite3
AGENT_CHECKPOINT_DB_PATH=./var/mail-agent/checkpoints.sqlite3
MAIL_ENV_FILE=./yandex/mail/.env
DRIVE_ENV_FILE=./yandex/drive/.env
MAILBOX=INBOX
POLL_INTERVAL_SECONDS=60
MAIL_BATCH_SIZE=50
MAX_CONCURRENT_MESSAGES=1
MARK_READ_AFTER_SUCCESS=true
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=3
LLM_MAX_TEXT_CHARS_PER_REQUEST=8000
LLM_MAX_COMPLETION_TOKENS=1200
LLM_MAX_OCR_CORRECTION_TOKENS=3000
OCR_BASE_URL=http://127.0.0.1:8000
OCR_FALLBACK_TO_VLM=true
OCR_TIMEOUT_SECONDS=300
OCR_MAX_RETRIES=3
TABLE_REMOTE_PATH=/mail-agent/mail-register.xlsx
TABLE_SHEET_NAME=Письма
LOG_LEVEL=INFO
