# Единый файл для Docker Compose и worker: не добавляйте рабочий `.env` в Git.
# Worker берёт ключ записи из WRITER_API_KEY и URL Results API из
# RESULTS_API_HOST/RESULTS_API_PORT, поэтому не нужно дублировать параметры.
POSTGRES_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
WRITER_API_KEY=
READER_API_KEY=
# Разрешает read-only API без ключа; включайте только в доверенной сети.
ALLOW_ANONYMOUS_READER=false
S3_BUCKET=mail-agent
RESULTS_API_HOST=127.0.0.1
RESULTS_API_PORT=8080
MINIO_CONSOLE_PORT=9001
