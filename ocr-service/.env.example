APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

PADDLE_DEVICE=cpu
PADDLE_ENABLE_MKLDNN=false
PADDLE_MODEL_HOME=/models
PADDLE_MODEL_SOURCE=huggingface

MAX_UPLOAD_SIZE_MB=25
MAX_PDF_PAGES=50
MAX_CONCURRENT_INFERENCES=2
MODEL_CACHE_SIZE=4

DEFAULT_OCR_MODEL=pp-ocrv6
DEFAULT_OCR_LANGUAGE=en

DEFAULT_PARSER_MODEL=pp-structurev3
DEFAULT_PARSER_LANGUAGE=en

TEMP_DIR=
REQUEST_TIMEOUT_SECONDS=300
