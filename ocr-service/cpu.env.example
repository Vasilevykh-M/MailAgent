# OCR размещён на отдельном хосте. Ограничьте TCP/8000 firewall только IP агента.
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

PADDLE_DEVICE=cpu
PADDLE_ENABLE_MKLDNN=false
# Каталог должен быть постоянным и доступным для записи пользователю сервиса.
PADDLE_MODEL_HOME=./models
PADDLE_MODEL_SOURCE=huggingface

MAX_UPLOAD_SIZE_MB=25
MAX_PDF_PAGES=50
# CPU-профиль не конкурирует с выгрузкой весов LLM в RAM.
MAX_CONCURRENT_INFERENCES=1
MODEL_CACHE_SIZE=1

DEFAULT_OCR_MODEL=pp-ocrv5
DEFAULT_OCR_LANGUAGE=ru
DEFAULT_PARSER_MODEL=pp-structurev3
DEFAULT_PARSER_LANGUAGE=ru

TEMP_DIR=./tmp
REQUEST_TIMEOUT_SECONDS=300
